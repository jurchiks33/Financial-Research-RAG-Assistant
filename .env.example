# =========================================
# Financial Research RAG Assistant
# Environment Configuration Template
# Copy this file to .env and fill in values
# =========================================

# -------------------------
# App / General
# -------------------------
APP_NAME=financial-research-rag-assistant
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# -------------------------
# API / Backend
# -------------------------
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-to-a-long-random-secret-key

# -------------------------
# OpenAI / LLM
# -------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -------------------------
# Vector Database / Retrieval
# -------------------------
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma

# Optional alternative
# VECTOR_DB_TYPE=faiss
# FAISS_INDEX_DIR=./data/faiss

# -------------------------
# Database
# -------------------------
DATABASE_URL=sqlite:///./data/app.db

# Optional Postgres example
# DATABASE_URL=postgresql://user:password@localhost:5432/financial_rag

# -------------------------
# Document Storage / Uploads
# -------------------------
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_FILE_TYPES=pdf,txt,md,docx

# -------------------------
# Retrieval / Chunking
# -------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5

# -------------------------
# CORS
# -------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -------------------------
# Evaluation / Experimentation
# -------------------------
EVAL_DATA_DIR=./data/eval
SAVE_RETRIEVAL_LOGS=true

# -------------------------
# Optional External Data APIs
# -------------------------
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=

# -------------------------
# Docker / Container
# -------------------------
DOCKER_ENV=false